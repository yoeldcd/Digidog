{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023", "DOM"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "skipLibCheck": true
  },
  "include": [
    "src/application/contracts/**/*.ts",
    "src/infrastructure/api/brain-api-client.ts",
    "src/presentation/utils/notification-message.ts",
    "src/presentation/state/app-state.ts"
  ]
}
