# Python and tool caches
*.pyc
*.pyo
__pycache__/
.pytest_cache/
.mypy_cache/
.ruff_cache/
node_modules/

# Agent-authored private state
/memory/*
!/memory/profiles/
/memory/profiles/*
!/memory/profiles/developer/
!/memory/profiles/developer/**
/pictures/
/$workspaces/

# Agent-local temporary artifacts
/.tmp/*
!/.tmp/.gitkeep

# Workspace-local runtime state
/$agent/.tmp/
/$agent/database/
/$agent/logs/

# Generated documentation exports
/core/**/documentation/wiki/
